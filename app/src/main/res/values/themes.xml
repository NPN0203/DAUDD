<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Theme cũ của bạn -->
    <style name="Base.Theme.DAUD" parent="Theme.Material3.DayNight.NoActionBar">
    </style>
    <style name="Theme.DAUD" parent="Base.Theme.DAUD" />

    <!-- Style cho trang cá nhân -->
    <style name="ProfileTopItem">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="ProfileTopIcon">
        <item name="android:layout_width">28dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:tint">#5C6BC0</item>
    </style>

    <style name="ProfileTopText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">#333333</item>
    </style>

    <style name="ProfileListItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingHorizontal">20dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <style name="ProfileListIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
    </style>

    <style name="ProfileListText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">#333333</item>
    </style>

    <!-- Style cho Channel Item trong trang Kênh của tôi -->
    <style name="ChannelItem">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">#F5F5F5</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">13sp</item>
    </style>
</resources>