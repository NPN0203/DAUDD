<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEEEE"
    tools:context=".MainActivity">

    <!-- Container cho Trang Chủ (Tin tức) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/homeContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/headerBar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="#D32F2F"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toTopOf="parent"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:background="@android:color/white"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#999999"
                    android:contentDescription="@null" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/search_hint"
                    android:textColor="#999999"
                    android:layout_marginStart="8dp"
                    android:textSize="14sp" />
            </LinearLayout>

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="12dp"
                android:src="@android:drawable/ic_menu_today"
                app:tint="@android:color/white"
                android:contentDescription="@null" />
        </LinearLayout>

        <!-- Category Bar -->
        <LinearLayout
            android:id="@+id/categoryBar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@android:color/white"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/headerBar"
            android:baselineAligned="false">

            <HorizontalScrollView
                android:id="@+id/categoryTabs"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scrollbars="none">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="8dp"
                    android:baselineAligned="false">
                    <TextView android:id="@+id/tabTrangChu" android:layout_width="wrap_content" android:layout_height="match_parent" android:text="@string/tab_home" android:textColor="#D32F2F" android:textStyle="bold" android:gravity="center" android:paddingHorizontal="12dp" />
                    <TextView android:id="@+id/tabBongDa" android:layout_width="wrap_content" android:layout_height="match_parent" android:text="@string/tab_football" android:textColor="#555555" android:gravity="center" android:paddingHorizontal="12dp" />
                    <TextView android:id="@+id/tabVideo" android:layout_width="wrap_content" android:layout_height="match_parent" android:text="@string/tab_video" android:textColor="#555555" android:gravity="center" android:paddingHorizontal="12dp" />
                    <TextView android:id="@+id/tabXaHoi" android:layout_width="wrap_content" android:layout_height="match_parent" android:text="@string/tab_social" android:textColor="#555555" android:gravity="center" android:paddingHorizontal="12dp" />
                    <TextView android:id="@+id/tabGiaiTri" android:layout_width="wrap_content" android:layout_height="match_parent" android:text="@string/tab_entertainment" android:textColor="#555555" android:gravity="center" android:paddingHorizontal="12dp" />
                    <TextView android:id="@+id/tabTheGioi" android:layout_width="wrap_content" android:layout_height="match_parent" android:text="@string/tab_world" android:textColor="#555555" android:gravity="center" android:paddingHorizontal="12dp" />
                </LinearLayout>
            </HorizontalScrollView>

            <ImageView
                android:id="@+id/btnOpenChannels"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:padding="14dp"
                android:src="@android:drawable/ic_menu_more"
                app:tint="#555555"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@null" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvNews"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/categoryBar"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Container cho Trang Khám Phá -->
    <FrameLayout
        android:id="@+id/exploreContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">
        <include layout="@layout/layout_explore" />
    </FrameLayout>

    <!-- Container cho Trang Cá Nhân (Tôi) -->
    <FrameLayout
        android:id="@+id/profileContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">
        <include layout="@layout/layout_profile" />
    </FrameLayout>

    <!-- Container cho Trang "Kênh của tôi" (Modal đè lên) -->
    <FrameLayout
        android:id="@+id/channelsContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#FFFFFF">
        <include layout="@layout/layout_channels" />
    </FrameLayout>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@android:color/white"
        android:orientation="horizontal"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:baselineAligned="false">

        <LinearLayout
            android:id="@+id/btnNavHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/ivNavHome"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_today"
                app:tint="#D32F2F"
                android:contentDescription="@null" />
            <TextView
                android:id="@+id/tvNavHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_home"
                android:textSize="11sp"
                android:textColor="#D32F2F" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnNavExplore"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/ivNavExplore"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_compass"
                app:tint="#777777"
                android:contentDescription="@null" />
            <TextView
                android:id="@+id/tvNavExplore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_explore"
                android:textSize="11sp"
                android:textColor="#777777" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnNavProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/ivNavProfile"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#777777"
                android:contentDescription="@null" />
            <TextView
                android:id="@+id/tvNavProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_me"
                android:textSize="11sp"
                android:textColor="#777777" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>