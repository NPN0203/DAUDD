<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THÊM BÀI BÁO MỚI"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#D32F2F"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/etAdminTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tiêu đề bài báo"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etAdminSource"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nguồn / Chuyên mục (Ví dụ: Bóng đá)"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etAdminImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="URL Hình ảnh"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etAdminContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nội dung bài báo"
            android:gravity="top"
            android:minLines="5"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnSaveNews"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Lưu bài báo"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>
